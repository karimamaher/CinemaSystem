@model Actor
<div class="container my-5">

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="col-12">
                <h2 class="display-6 fw-bold"> Actor Details</h2>
            </div>

            <div class="card shadow border-0 rounded-4 overflow-hidden">

                <!-- Cover -->
                <div class="bg-info" style="height:150px;"></div>


                <div class="card-body text-center">

                    <!-- Actor Image -->
                    <img src="~/images/actors/@Model.Img"
                         class="rounded-circle shadow border border-5 border-white"
                         style="width:150px;height:150px;object-fit:cover;margin-top:-90px;" />

                    <!-- Name -->
                    <h3 class="mt-3 fw-bold">@Model.Name</h3>

                    <!-- Movie -->
                    <p class="text-muted mb-3">
                        In Movie:
                        <span class="fw-semibold text-dark">
                            @Model.Movie?.Name
                        </span>
                    </p>

                    <!-- Info Cards -->
                    <div class="row text-center mt-4">

                        <div class="col-md-6 mb-3">
                            <div class="p-3 border rounded-3 bg-light">
                                <small class="text-muted d-block">Actor ID</small>
                                <span class="fw-semibold">@Model.Id</span>
                            </div>
                        </div>

                        <div class="col-md-6 mb-3">
                            <div class="p-3 border rounded-3 bg-light">
                                <small class="text-muted d-block">Movie ID</small>
                                <span class="fw-semibold">@Model.MovieId</span>
                            </div>
                        </div>

                    </div>

                    <!-- Buttons -->
                    <div class="mt-4 d-flex justify-content-center gap-2">

                        <a href="/Admin/Actor/Update/@Model.Id"
                           class="btn btn-outline-primary px-4">
                            Edit
                        </a>

                        <a href="/Admin/Actor/Delete/@Model.Id"
                           class="btn btn-outline-danger px-4">
                            Delete
                        </a>

                        <a href="/Admin/Movie/Index"
                           class="btn btn-secondary px-4">
                            Back
                        </a>

                    </div>

                </div>

            </div>

        </div>
    </div>

</div>