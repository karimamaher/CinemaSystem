@model Category
<div class="container">
    <div class="row mb-3 align-items-center my-4">
        <div class="col-12">
            <h2 class="display-6 fw-bold">Create New Category</h2>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <form method="post">
                        <!-- Name -->
                        <div class="mb-3">
                            <label for="Name" class="form-label fw-semibold">Name</label>
                            <input type="text" class="form-control form-control-lg" placeholder="Enter category name" asp-for="Name">
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <!-- Status -->
                        <div class="mb-4">
                            <label for="Status" class="form-label fw-semibold">Status</label>
                            <select name="status" class="form-select form-select-lg" id="Status">
                                @if (Model.Status)
                                {
                                    <option value="true" selected>Active</option>
                                    <option value="false">In Active</option>
                                }
                                else
                                {
                                    <option value="true">Active</option>
                                    <option value="false" selected>In Active</option>
                                }
                            </select>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                            <i class="fas fa-plus me-2"></i> Create Category
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial">
}
