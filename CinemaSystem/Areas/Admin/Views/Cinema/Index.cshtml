@model CinemasVM

<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">All Cinemas</h2>
        </div>
        <div class="col-md-6 text-md-end text-start mt-2 mt-md-0">
            <a href="/Admin/Cinema/Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Create</a>
        </div>
    </div>


    <!-- Filter Section -->
    <section class="py-3 filter-bar">
        <div class="container">
            <div class="row justify-content-end">
                <div class="col-md-5">
                    <form>
                        <div class="input-group shadow-sm">

                            <!-- Input -->
                            <input type="search"
                                   class="form-control form-control-sm"
                                   placeholder="CinemaName..."
                                   name="query"
                                   value="@ViewBag.Query" />

                            <!-- Button -->
                            <button type="submit" class="btn btn-dark">
                                <i class="fa fa-search"></i>
                            </button>

                        </div>
                    </form>
                </div>
            </div>
        </div>

    </section>
        <div class="card shadow-sm border-0">
            <div class="card-body">

                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">

                        <thead class="table-light">
                            <tr>
                                <th>Id</th>
                                <th>Name</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Cinemas)
                            {
                                <tr>
                                    <td class="fw-semibold">@item.Id</td>

                                    <td>@item.Name</td>

                                    <td>
                                        @if (item.Status)
                                        {
                                            <span class="badge bg-success-subtle text-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger-subtle text-danger">Inactive</span>
                                        }
                                    </td>

                                    <td class="text-end">
                                        <a href="/Admin/Cinema/Update/@item.Id"
                                           class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <a href="/Admin/Cinema/Delete/@item.Id"
                                           class="btn btn-sm btn-outline-danger btn-delete">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>

       
    <div class="d-flex justify-content-center mt-3">
        <ul class="pagination mb-0">
            @if (Model.CurrentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       href="/Admin/Cinema/Index?page=@(Model.CurrentPage - 1)"
                       title="Previous">
                        <span class="fas fa-chevron-left"></span>
                    </a>
                </li>
            }

            @for (var i = 1; i <= Model.TotalPages; i++)
            {
                @if (i == Model.CurrentPage)
                {
                    <li class="page-item active"><a class="page-link" href="/Admin/Cinema/Index?page=@i">@i</a></li>
                }
                else
                {
                    <li class="page-item"><a class="page-link" href="/Admin/Cinema/Index?page=@i">@i</a></li>
                }
            }

            @if (Model.CurrentPage != Model.TotalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="/Admin/Cinema/Index?page=@(Model.CurrentPage + 1)" title="Next">
                        <span class="fas fa-chevron-right"></span>
                    </a>
                </li>
            }
        </ul>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const deleteButtons = document.querySelectorAll(".btn-delete");

        deleteButtons.forEach(button => {
            button.addEventListener("click", function (e) {
                e.preventDefault(); // stop normal navigation

                const url = this.getAttribute("href");

                Swal.fire({
                    title: "Are you sure?",
                    text: "This action cannot be undone!",
                    icon: "warning",
                    showCancelButton: true,
                    confirmButtonColor: "#d33",
                    cancelButtonColor: "#3085d6",
                    confirmButtonText: "Yes, delete it!"
                }).then((result) => {
                    if (result.isConfirmed) {
                        Swal.fire({
                          title: "Deleted!",
                          text: "Your file has been deleted.",
                          icon: "success"
                        });

                        // Redirect to delete URL
                        window.location.href = url;
                    }
                });
            });
        });
    });

</script>

