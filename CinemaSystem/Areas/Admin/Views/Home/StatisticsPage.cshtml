@section Styles {
    <style>
        body {
            background-color: #f5f7fb;
        }

        .dashboard-card {
            border-radius: 14px;
            transition: all 0.3s ease;
        }

            .dashboard-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 30px rgba(0,0,0,0.08);
            }

        .icon-box {
            width: 60px;
            height: 60px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 26px;
        }
    </style>
}
@model StatisticsPageVM

<div class="container-fluid py-4">

    <!-- 🔷 Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
        <div>
            <h3 class="fw-bold mb-1">Good Morning 👋</h3>
            <p class="text-muted mb-0">Here's what's happening with your cinema today.</p>
        </div>

    </div>

    <!-- 🔷 Cards -->
    <div class="row g-4">

        <!-- Movies -->
        <div class="col-md-6 col-xl-3">
            <a asp-controller="Movie" asp-action="Index" class="text-decoration-none">
                <div class="card dashboard-card border-0 shadow-sm h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1">Total Movies</p>
                            <h3 class="fw-bold">@Model.MoviesCount</h3>
                            <a asp-controller="Movie" asp-action="Index"
                               class="text-primary small fw-semibold text-decoration-none">
                                View details →
                            </a>
                        </div>
                        <div class="icon-box bg-primary-subtle text-primary">
                            <i class="bi bi-film"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <!-- Actors -->
        <div class="col-md-6 col-xl-3">
            <a asp-controller="Actor" asp-action="Index" class="text-decoration-none">
                <div class="card dashboard-card border-0 shadow-sm h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1">Total Actors</p>
                            <h3 class="fw-bold">@Model.ActorsCount</h3>
                            <a asp-controller="Actor" asp-action="Index"
                               class="text-primary small fw-semibold text-decoration-none">
                                View details →
                            </a>
                        </div>
                        <div class="icon-box bg-success-subtle text-success">
                            <i class="bi bi-people"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <!-- Cinemas -->
        <div class="col-md-6 col-xl-3">
            <a asp-controller="Cinema" asp-action="Index" class="text-decoration-none">
                <div class="card dashboard-card border-0 shadow-sm h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1">Total Cinemas</p>
                            <h3 class="fw-bold">@Model.CinemasCount</h3>
                            <a asp-controller="Cinema" asp-action="Index"
                               class="text-primary small fw-semibold text-decoration-none">
                                View details →
                            </a>
                        </div>
                        <div class="icon-box bg-warning-subtle text-warning">
                            <i class="bi bi-building"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>

        <!-- Categories -->
        <div class="col-md-6 col-xl-3">
            <a asp-controller="Category" asp-action="Index" class="text-decoration-none">
                <div class="card dashboard-card border-0 shadow-sm h-100">
                    <div class="card-body d-flex justify-content-between align-items-center">
                        <div>
                            <p class="text-muted mb-1">Total Categories</p>
                            <h3 class="fw-bold">@Model.CategoriesCount</h3>
                            <a asp-controller="Category" asp-action="Index"
                               class="text-primary small fw-semibold text-decoration-none">
                                View details →
                            </a>
                        </div>
                        <div class="icon-box bg-danger-subtle text-danger">
                            <i class="bi bi-tags"></i>
                        </div>
                    </div>
                </div>
            </a>
        </div>

    </div>

    <!-- 🔷 Extra Section -->
    <div class="row mt-5 g-4">

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-bar-chart-line me-2 text-primary"></i>
                        Overview
                    </h5>

                    <div class="row text-center">

                        <div class="col">
                            <h4 class="fw-bold">@Model.MoviesCount</h4>
                            <p class="text-muted mb-0">Movies</p>
                        </div>

                        <div class="col">
                            <h4 class="fw-bold">@Model.ActorsCount</h4>
                            <p class="text-muted mb-0">Actors</p>
                        </div>

                        <div class="col">
                            <h4 class="fw-bold">@Model.CinemasCount</h4>
                            <p class="text-muted mb-0">Cinemas</p>
                        </div>

                        <div class="col">
                            <h4 class="fw-bold">@Model.CategoriesCount</h4>
                            <p class="text-muted mb-0">Categories</p>
                        </div>

                    </div>

                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <h6 class="text-muted">System Status</h6>
                    <h4 class="fw-bold text-success mt-2">
                        <i class="bi bi-check-circle-fill me-1"></i>
                        Running Smoothly
                    </h4>
                    <p class="text-muted small">All systems are working fine.</p>
                </div>
            </div>
        </div>

    </div>

</div>