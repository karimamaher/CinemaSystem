@model MovieWithSubImgsVM
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h2 class="display-6">Update Movie</h2>
        </div>
    </div>
    <div class="row my-3">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Movie.Id" />
                        <div class="mb-3">
                            <label for="Name" class="form-label fw-semibold">Name</label>
                            <input class="form-control form-control-lg" placeholder="Name" asp-for="Movie.Name">
                            <span asp-validation-for="Movie.Name" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label for="Description" class="form-label fw-semibold">Description</label>
                            <textarea class="form-control form-control-lg" asp-for="Movie.Description" rows="3"></textarea>
                            <span asp-validation-for="Movie.Description" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label for="Price" class="form-label fw-semibold">Price</label>
                            <input class="form-control form-control-lg" placeholder="Price" asp-for="Movie.Price">
                            <span asp-validation-for="Movie.Price" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label for="DateTime" class="form-label fw-semibold">DateTime</label>
                            <input class="form-control form-control-lg" placeholder="DateTime" asp-for="Movie.DateTime">
                            <span asp-validation-for="Movie.DateTime" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label for="CategoryName" class="form-label fw-semibold">Category Name</label>
                            <select asp-for="Movie.CategoryId" class="form-select">
                                @foreach (var item in Model.Categories)
                                {
                                    <option value="@item.Id">@item.Name</option>
                                }
                            </select>
                            <span asp-validation-for="Movie.CategoryId" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label for="CinemaName" class="form-label fw-semibold">Cinema Name</label>
                            <select  asp-for="Movie.CinemaId"  class="form-select">
                                @foreach (var item in Model.Cinemas)
                                {
                                    <option value="@item.Id">@item.Name</option>                                    
                                }
                            </select>
                            <span asp-validation-for="Movie.CinemaId" class="text-danger"></span>
                        </div>

                        <input type="hidden" asp-for="Movie.MainImg" />

                        <div class="mb-3">
                            <label for="Img" class="form-label fw-semibold">Img</label>
                            <input type="file" class="form-control form-control-lg" id="Img" name="Img" onchange="preViewImage(event)">
                        </div>
                        <div class="mb-3">
                            <img id="preview" src="~/images/movies/@Model.Movie.MainImg" alt="Current Image" style="max-width:200px ; border:1px solid #ccc ;padding:5px; border-radius:10px;" />
                        </div> 
                        <div class="mb-3">
                            <label for="SubImgs" class="form-label">Sub Imgs</label> 
                            <input type="file" class="form-control" id="SubImgs" name="SubImgs" multiple>
                            </div> 
                            <div class="mb-3">
                            @foreach (var item in Model.MovieSubImgs)
                            {
                                <img  src="~/images/movies/SubImgs/@item.SubImg" alt="Current Image" style="max-width:200px ; border:1px solid #ccc ;padding:5px; border-radius:10px;" />
                            }
                        </div>
                        <div class="mb-3">
                            <label for="Status" class="form-label fw-semibold">Status</label>
                            <select asp-for="Movie.Status" class=" form-select" >
                                @if (Model.Movie.Status)
                                {
                                    <option value="true" selected>Active</option>
                                    <option value="false">In Active</option>
                                }
                                else
                                {
                                    <option value="true">Active</option>
                                    <option value="false" selected>In Active</option>
                                }
                            </select>
                        </div>
                        <!-- Submit Button -->
                        <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm">
                            <i class="fas fa-edit me-2"></i> Update Movie
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
        function preViewImage(event) {
        const input = event.target;
        const preview = document.getElementById("preview");

        if (input.files && input.files[0]) {
            const reader = new FileReader();

            reader.onload = function (e) {
                preview.src = e.target.result;
            }

            reader.readAsDataURL(input.files[0]);
        }
    }
</script>


@section Scripts {
    <partial name="_ValidationScriptsPartial">
}
