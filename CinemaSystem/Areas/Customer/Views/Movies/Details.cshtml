@model MovieDetailsVM

@section Styles {
    <style>
        .poster {
            height: 350px;
            border-radius: 12px;
            overflow: hidden;
        }

            .poster img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .actor-img {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            overflow: hidden;
        }

            .actor-img img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .showtime-box {
            padding: 10px;
            border-radius: 10px;
            border: 1px solid #eee;
            transition: 0.3s;
        }

            .showtime-box:hover {
                background: #f8f9fa;
                transform: scale(1.05);
            }

        .time {
            font-weight: bold;
            font-size: 18px;
        }
    </style>
}

<div class="container my-5">

    <div class="row">

        <!-- 🎬 الصورة -->
        <div class="col-md-3">
            <div class="poster shadow">
                <img src="~/images/movies/@Model.Movie.MainImg" />
            </div>
        </div>

        <!-- 📄 التفاصيل -->
        <div class="col-md-5">

            <h2 class="fw-bold">@Model.Movie.Name</h2>

            <p class="text-muted">
                @Model.Movie.Category?.Name
            </p>

            <p>
                <b>Cinema:</b> @Model.Movie.Cinema?.Name
            </p>

            <p>@Model.Movie.Description</p>

            <!-- Actors -->
            <div class="mt-3">
                <h6>Cast</h6>

                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var actor in Model.Movie.Actors)
                    {
                        <div class="text-center">
                            <div class="actor-img">
                                <img src="~/images/actors/@actor.Img" />
                            </div>
                            <small>@actor.Name</small>
                        </div>
                    }
                </div>
            </div>

        </div>

        <!-- ⏰ ShowTimes -->
        <div class="col-md-4">

            <h5 class="mb-4 fw-bold">ShowTimes 🎟️</h5>

            @if (Model.ShowTimes != null && Model.ShowTimes.Any())
            {
                @foreach (var show in Model.ShowTimes)
                {
                    <div class="showtime-row d-flex justify-content-between align-items-center mb-3 p-3 shadow-sm">

                        <!-- الوقت -->
                        <div>
                            <div class="time">
                                @show.StartTime.ToString("hh:mm tt")
                            </div>
                            <small class="text-muted">
                                @show.StartTime.ToString("dddd")
                            </small>
                        </div>

                        <!-- القاعة -->
                        <div>
                            <small>Hall</small><br />
                            <b>@show.Hall?.HallName</b>
                        </div>

                        <!-- السعر -->
                        <div class="text-success fw-bold">
                            @show.Price EGP
                        </div>

                        <!-- زر الحجز -->
                        <div>
                            <a asp-controller="Seats"
                               asp-action="SelectSeats"
                               asp-route-showTimeId="@show.ShowTimeId"
                               class="btn btn-warning px-4">
                                Book
                            </a>
                        </div>

                    </div>
                }
            }
            else
            {
                <p>No showtimes</p>
            }

        </div>

    </div>

</div>