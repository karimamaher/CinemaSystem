@model MoviesVM

<div class="container my-5">

    <!-- 🔍 Filters -->
    <form method="get" class="row mb-4">

        <div class="col-md-4">
            <input type="text" name="Name" value="@ViewBag.Name"
                   class="form-control" placeholder="Search movie..." />
        </div>

        <div class="col-md-3">
            <select name="CategoryId" class="form-control">
                <option value="">All Categories</option>
                @foreach (var cat in Model.Categories)
                {
                    <option value="@cat.Id"
                            selected="@(ViewBag.CategoryId == cat.Id)">
                        @cat.Name
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <select name="CinemaId" class="form-control">
                <option value="">All Cinemas</option>
                @foreach (var c in Model.Cinemas)
                {
                    <option value="@c.Id"
                            selected="@(ViewBag.CinemaId == c.Id)">
                        @c.Name
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button class="btn btn-primary w-100">Filter</button>
        </div>
    </form>


    <div class="row">

        @foreach (var movie in Model.Movies)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100">
                    <div>
                        <img src="~/images/movies/@movie.MainImg"
                             class="card-img-top"
                             style="height:350px; width:100%; object-fit:cover;" />
                    </div>


                    <div class="card-body d-flex flex-column">

                        <h5 class="card-title">@movie.Name</h5>

                        <p class="text-muted">
                            @movie.Category?.Name
                        </p>

                        <p>
                            Cinema: <b>@movie.Cinema?.Name</b>
                        </p>

                        <div class="mt-auto">
                            <a asp-action="Details"
                               asp-route-id="@movie.Id"
                               class="btn btn-success w-100">
                                View Details
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }

    </div>

    <!-- 📄 Pagination -->
    <div class="d-flex justify-content-center mt-4">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <a asp-action="Index"
               asp-route-page="@i"
               class="btn @(i == Model.CurrentPage ? "btn-dark" : "btn-outline-dark") mx-1">
                @i
            </a>
        }

    </div>

</div>
