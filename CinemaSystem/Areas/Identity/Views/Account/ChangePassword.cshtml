@model ChangePasswordVM

@{
    ViewData["Title"] = "ChangePassword";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 100vh; background: linear-gradient(135deg, #eef2f7, #f8f9fb);">
    <div class="row w-100 justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8 col-11">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="text-center p-4" style="background-color: #0d6efd; color: white;">
                    <h2 class="fw-bold mb-1">Change Password</h2>
                    <small>Create a new secure password</small>
                </div>

                <!-- Body -->
                <div class="card-body p-5">

                    <p class="text-center text-muted mb-4 fs-5">
                        Enter your new password and confirm it to continue
                    </p>

                    <form asp-action="ChangePassword">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Password -->
                        <div class="form-group mb-4">
                            <label asp-for="Password" class="form-label fw-semibold fs-5"></label>
                            <input asp-for="Password"
                                   type="password"
                                   class="form-control form-control-lg rounded-3 shadow-sm"
                                   placeholder="Enter new password" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <!-- Confirm Password -->
                        <div class="form-group mb-4">
                            <label asp-for="ConfirmPassword" class="form-label fw-semibold fs-5"></label>
                            <input asp-for="ConfirmPassword"
                                   type="password"
                                   class="form-control form-control-lg rounded-3 shadow-sm"
                                   placeholder="Confirm new password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <!-- Submit -->
                        <div class="d-grid mb-4">
                            <input type="submit"
                                   value="Update Password"
                                   class="btn btn-primary btn-lg rounded-3 fw-semibold shadow-sm" />
                        </div>

                        <!-- Back -->
                        <div class="text-center">
                            <a asp-action="Index" class="text-decoration-none fw-semibold text-primary">
                                Back
                            </a>
                        </div>
                    </form>

                </div>

                <!-- Footer -->
                <div class="text-center py-3 bg-light">
                    <small class="text-muted">Your password is securely updated</small>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotificationPartial">
}
