@model ForgetPasswordVM

@{
    ViewData["Title"] = "ForgetPassword";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 100vh; background: linear-gradient(135deg, #eef2f7, #f8f9fb);">
    <div class="row w-100 justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8 col-11">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="text-center p-4" style="background-color: #0d6efd; color: white;">
                    <h2 class="fw-bold mb-1">Forgot Password?</h2>
                    <small>We’ll help you reset it quickly</small>
                </div>

                <!-- Body -->
                <div class="card-body p-5">

                    <p class="text-center text-muted mb-4 fs-5">
                        Enter your email or username and we’ll send you a reset link
                    </p>

                    <form asp-action="ForgetPassword">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="EmailOrUserName" class="form-label fw-semibold fs-5"></label>
                            <input asp-for="EmailOrUserName"
                                   class="form-control form-control-lg rounded-3 shadow-sm"
                                   placeholder="Enter your email or username" />
                            <span asp-validation-for="EmailOrUserName" class="text-danger"></span>
                        </div>

                        <div class="d-grid mb-4">
                            <input type="submit"
                                   value="Send Reset Link"
                                   class="btn btn-primary btn-lg rounded-3 fw-semibold shadow-sm" />
                        </div>

                        <div class="text-center">
                            <a asp-action="Login" class="text-decoration-none fw-semibold text-primary">
                                Back to Login
                            </a>
                        </div>
                    </form>

                </div>

                <!-- Footer -->
                <div class="text-center py-3 bg-light">
                    <small class="text-muted">Secure password reset system</small>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotificationPartial">
}

