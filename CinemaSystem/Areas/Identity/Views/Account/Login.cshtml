@model LoginVM

@{
    ViewData["Title"] = "Login";
}
@section Styles {
    <style>
        body {
            margin: 0;
            padding: 0;
            height: 100vh;
            background: linear-gradient(120deg, #141e30, #243b55);
            font-family: 'Segoe UI', sans-serif;
            overflow: hidden;
        }

        .login-wrapper {
            width: 100%;
            height: 100vh;
            display: flex;
        }

        /* Left Side (Image / Branding) */
        .left-side {
            width: 60%;
            background: url('https://images.unsplash.com/photo-1524985069026-dd778a71c7b4') center/cover no-repeat;
            position: relative;
        }

        .left-overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-align: center;
            padding: 40px;
        }

            .left-overlay h1 {
                font-size: 50px;
                font-weight: bold;
            }

            .left-overlay p {
                font-size: 18px;
                opacity: 0.8;
            }

        /* Right Side (Form) */
        .right-side {
            width: 40%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(15px);
        }

        .login-box {
            width: 85%;
            max-width: 420px;
            background: rgba(255,255,255,0.08);
            padding: 40px;
            border-radius: 20px;
            backdrop-filter: blur(20px);
            box-shadow: 0 20px 60px rgba(0,0,0,0.4);
            color: white;
        }

            .login-box h2 {
                text-align: center;
                margin-bottom: 30px;
                font-weight: bold;
            }

        .form-control {
            background: rgba(255,255,255,0.1);
            border: none;
            border-radius: 12px;
            padding: 12px;
            color: white;
        }

            .form-control::placeholder {
                color: #ccc;
            }

            .form-control:focus {
                background: rgba(255,255,255,0.15);
                box-shadow: none;
                color: white;
            }

        .btn-primary {
            width: 100%;
            border-radius: 12px;
            padding: 12px;
            font-size: 18px;
            background: linear-gradient(135deg, #ff416c, #ff4b2b);
            border: none;
            transition: 0.3s;
        }

            .btn-primary:hover {
                transform: scale(1.05);
            }

        .links a {
            display: block;
            margin-top: 10px;
            color: #ddd;
            text-decoration: none;
            font-size: 14px;
        }

            .links a:hover {
                color: white;
            }

        @@media(max - width: 900px) {
            .left-side {
                display: none;
            }

            .right-side {
                width: 100%;
            }
        }
    </style>

}


<div class="login-wrapper">

    <!-- Left -->
    <div class="left-side">
        <div class="left-overlay">
            <div>
                <h1>Cinema World</h1>
                <p>Experience movies like never before</p>
            </div>
        </div>
    </div>

    <!-- Right -->
    <div class="right-side">
        <div class="login-box">

            <h2>Login</h2>

            <form asp-action="Login">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <input asp-for="UserNameOrEmail" class="form-control" placeholder="Username or Email" />
                    <span asp-validation-for="UserNameOrEmail" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <input asp-for="Password" class="form-control" placeholder="Password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="RememberMe" />
                    <label class="form-check-label">
                        @Html.DisplayNameFor(model => model.RememberMe)
                    </label>
                </div>

                <input type="submit" value="Login" class="btn btn-primary" />
            </form>

            <div class="links mt-3 text-center">
                <a asp-action="Register">Create Account</a>
                <a asp-action="ForgetPassword">Forgot Password?</a>
                <a asp-action="ResendEmailConfirmation">Resend Email Confirmation</a>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotificationPartial">
}
