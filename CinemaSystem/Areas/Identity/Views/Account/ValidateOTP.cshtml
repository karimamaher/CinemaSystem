@model ValidateOTPVM

@{
    ViewData["Title"] = "ValidateOTP";
}

<div class="container-fluid d-flex align-items-center justify-content-center" style="min-height: 100vh; background: linear-gradient(135deg, #eef2f7, #f8f9fb);">
    <div class="row w-100 justify-content-center">
        <div class="col-xl-5 col-lg-6 col-md-8 col-11">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="text-center p-4" style="background-color: #0d6efd; color: white;">
                    <h2 class="fw-bold mb-1">Verify Code</h2>
                    <small>Enter the OTP sent to you</small>
                </div>

                <!-- Body -->
                <div class="card-body p-5">

                    <p class="text-center text-muted mb-4 fs-5">
                        Please enter the verification code to continue
                    </p>

                    <form asp-action="ValidateOTP">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-4">
                            <label asp-for="OTP" class="form-label fw-semibold fs-5"></label>
                            <input asp-for="OTP"
                                   class="form-control form-control-lg rounded-3 shadow-sm text-center"
                                   placeholder="Enter OTP Code"
                                   style="letter-spacing: 8px; font-size: 1.5rem;" />
                            <span asp-validation-for="OTP" class="text-danger"></span>
                        </div>

                        <div class="d-grid mb-4">
                            <input type="submit"
                                   value="Verify Code"
                                   class="btn btn-primary btn-lg rounded-3 fw-semibold shadow-sm" />
                        </div>

                        <div class="text-center">
                            <a asp-action="Index" class="text-decoration-none fw-semibold text-primary">
                                Back
                            </a>
                        </div>
                    </form>

                </div>

                <!-- Footer -->
                <div class="text-center py-3 bg-light">
                    <small class="text-muted">Secure verification process</small>
                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <partial name="_NotificationPartial">
}
